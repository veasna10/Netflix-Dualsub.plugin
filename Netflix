#!name = Netflix Dualsub
#!desc = Netflix 双语字幕，支持设置与字幕拦截。
#!author = Neurogram
#!icon = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Netflix.png

[Script]
# 匹配截图第一条规则：字幕消息处理
http-response ^https?:\/\/.*\.nflxvideo\.net\/.*\/msg\/.* script-path=https://raw.githubusercontent.com/Neurogram-R/Quantumult-X/main/Dualsub.js, requires-body=true, timeout=60, tag=Netflix字幕

# 匹配截图第二条规则：设置信息处理
http-response ^https?:\/\/setting\.nflxvideo\.net\/.*action=(g|s)et script-path=https://raw.githubusercontent.com/Neurogram-R/Quantumult-X/main/Dualsub.js, requires-body=true, timeout=60, tag=Netflix设置

[MITM]
hostname = *.nflxvideo.net, setting.nflxvideo.net
